# Gemini AI API key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth 2.0 credentials from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/callback
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Your WhatsApp number in international format (e.g. 919876543210@c.us)
YOUR_WHATSAPP_NUMBER=your_number_in_international_format

# Port for the Express server (optional, defaults to 3000)
PORT=3000
